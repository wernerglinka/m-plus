{
  "name": "m-plus",
  "version": "0.0.1",
  "description": "Metalsmith build wrapper — packages Metalsmith and all plugins into a single dependency",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./filters": "./lib/nunjucks-filters/index.js"
  },
  "keywords": [
    "metalsmith",
    "static-site-generator",
    "build-tool",
    "components",
    "structured-content"
  ],
  "author": "werner@glinka.co",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wernerglinka/m-plus.git"
  },
  "dependencies": {
    "@wernerglinka/marked-directive-block": "^1.0.0",
    "@wernerglinka/marked-extensions-shared": "^1.0.0",
    "@wernerglinka/marked-image-with-class": "^1.0.0",
    "@wernerglinka/marked-link-with-class": "^1.0.0",
    "@wernerglinka/marked-paragraph-with-class": "^1.0.1",
    "@metalsmith/collections": "^2.0.0",
    "@metalsmith/drafts": "^1.3.0",
    "@metalsmith/layouts": "^3.0.0",
    "@metalsmith/permalinks": "^3.2.0",
    "autoprefixer": "^10.4.27",
    "browser-sync": "^3.0.4",
    "cssnano": "^7.1.4",
    "jstransformer-nunjucks": "^1.2.0",
    "marked": "^18.0.0",
    "metalsmith": "2.6.3",
    "metalsmith-static-files": "^3.0.2",
    "metalsmith-bundled-components": "^0.9.1",
    "metalsmith-menu-plus": "^0.3.0",
    "metalsmith-optimize-html": "^0.8.3",
    "metalsmith-optimize-images": "^0.10.3",
    "metalsmith-safe-links": "^2.1.0",
    "metalsmith-search": "^0.2.0",
    "metalsmith-sectioned-blog-pagination": "^1.3.1",
    "metalsmith-multilingual": "github:wernerglinka/metalsmith-multilingual",
    "metalsmith-seo": "^0.4.0",
    "postcss": "^8.5.9",
    "postcss-import": "^16.1.1",
    "shiki": "^4.0.2",
    "stylelint": "^17.6.0"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
